# LLM Wiki local configuration.
# Copy this file to `.env` (which is gitignored) and adjust values for your setup.
# All keys are optional - unset keys fall back to the defaults shown here.

# IANA timezone used for daily log boundaries, compile trigger hour, and
# timestamps in wiki operations. Examples: UTC, America/Los_Angeles.
WIKI_TIMEZONE=UTC

# Local hour (0-23) after which flush.py will auto-trigger compile.py at
# session end. Set to a value that matches your working hours.
WIKI_COMPILE_AFTER_HOUR=18

# Maximum conversation turns captured from a transcript for flush processing.
WIKI_MAX_TURNS=30

# Maximum characters kept from a captured transcript before sending to flush.
WIKI_MAX_CONTEXT_CHARS=15000

# Minimum characters of meaningful context required before flush.py runs.
# Sessions shorter than this are silently skipped.
WIKI_MIN_FLUSH_CHARS=500

# Debounce window in seconds to prevent cascading flush/compact hook spawns.
WIKI_DEBOUNCE_SEC=10
